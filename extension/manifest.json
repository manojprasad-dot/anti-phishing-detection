{
  "manifest_version": 3,
  "name": "PhishGuard — AI Phishing Detector",
  "version": "2.0.0",
  "description": "AI-powered real-time phishing detection for websites and emails. Monitors URLs, scans email content, detects threats, and alerts users instantly.",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "notifications",
    "webNavigation",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],
  "content_security_policy": {
    "extension_pages": "default-src 'self'; connect-src 'self' https://phishguard-api-6dmc.onrender.com; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:;"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://mail.google.com/*",
        "https://outlook.live.com/*",
        "https://outlook.office.com/*",
        "https://outlook.office365.com/*"
      ],
      "js": ["gmail_scanner.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "PhishGuard"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["email_scanner.html", "email_scanner.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "commands": {
    "quick-scan": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Quick scan current page"
    }
  }
}
