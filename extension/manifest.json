{
  "manifest_version": 3,
  "name": "PhishGuard — AI Phishing Detector",
  "version": "1.0.0",
  "description": "AI-powered real-time phishing detection. Monitors URLs, detects threats, and alerts users instantly.",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "notifications",
    "webNavigation"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "PhishGuard"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
